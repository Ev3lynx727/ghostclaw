{
  "use_ai": true,
  "ai_provider": "openrouter",
  "ai_model": "anthropic/claude-3.5-sonnet",
  "ai_temperature": 0.7,
  "ai_max_tokens": 4096,
  "use_pyscn": null,
  "use_ai_codeindex": null,
  "cache_enabled": true,
  "cache_ttl_hours": 168,
  "parallel_enabled": true,
  "concurrency_limit": 32,
  "batch_size": 50,
  "large_file_threshold": 300,
  "max_files_to_analyze": 10000,
  "exclude_patterns": [
    "node_modules/",
    ".git/",
    "__pycache__/",
    "*.pyc",
    "venv/",
    ".venv/",
    "dist/",
    "build/",
    "*.egg-info/"
  ],
  "include_extensions": null,
  "dry_run": false,
  "verbose": false,
  "patch": false,
  "show_progress": true,
  "output_format": "json",
  "report_timestamp": true,
  "store_reports": true
}
