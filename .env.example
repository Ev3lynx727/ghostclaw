# Ghostclaw Environment Configuration
# Copy this file to .env and fill in the values.

# --- Ghost Engine (AI) Synthesis ---
# Enable Ghost Engine AI synthesis (default: false)
GHOSTCLAW_USE_AI=false
# AI Provider (openrouter, openai, anthropic)
GHOSTCLAW_AI_PROVIDER=
# API Key for the selected provider
GHOSTCLAW_API_KEY=

# --- Debugging & Development ---
# Enable Logfire native telemetry framework (0=off, 1=on)
GHOSTCLAW_TELEMETRY=0
# Dry run mode: prints prompt and token count without API call
GHOSTCLAW_DRY_RUN=false
# Verbose mode: saves raw API requests/responses to .ghostclaw/debug.log
GHOSTCLAW_VERBOSE=false

# --- Optional Engine Integrations ---
# Explicitly enable/disable PySCN (clone/dead code detection)
# GHOSTCLAW_USE_PYSCN=
# Explicitly enable/disable AI-CodeIndex (AST coupling graphs)
# GHOSTCLAW_USE_AI_CODEINDEX=

# --- Notifications & PRs ---
# GitHub token for creating PRs (ghostclaw --create-pr)
GH_TOKEN=

# Telegram bot token for notifications (ghostclaw-watcher --notify)
TELEGRAM_TOKEN=
# Telegram chat ID to receive notifications
TELEGRAM_CHAT_ID=

# --- Storage ---
# Optional: custom cache directory (default: ~/.cache/ghostclaw)
# GHOSTCLAW_CACHE_DIR=

# Supabase cloud storage (optional)
# Set to enable persisting reports to Supabase instead of local SQLite
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
