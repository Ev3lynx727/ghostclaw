# Ghostclaw Environment Configuration
# Copy this file to .env and fill in the values.

# GitHub token for creating PRs (ghostclaw-watcher --create-pr)
# Scope: repo (public_repo or private_repo for private repos)
GH_TOKEN=

# Telegram bot token for notifications (ghostclaw-watcher --notify)
# Create bot via @BotFather
TELEGRAM_TOKEN=

# Telegram chat ID to receive notifications
# For groups/channels: @getidsbot or @username_to_id_bot
TELEGRAM_CHAT_ID=

# Optional: custom cache directory (default: ~/.cache/ghostclaw)
# GHOSTCLAW_CACHE_DIR=
