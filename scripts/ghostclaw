#!/usr/bin/env python3
"""
Ghostclaw CLI — command-line interface for the architectural analyzer.
"""

import sys
import json
from pathlib import Path
from typing import Dict

# Ensure src directory is in sys.path to allow importing from the ghostclaw package
# This script is located in scripts/, so src is one level up + src/
sys.path.append(str(Path(__file__).parent.parent / "src"))

from dotenv import load_dotenv
from ghostclaw.core.analyzer import CodebaseAnalyzer

load_dotenv()


def print_report(report: Dict):
    """Pretty-print the analysis report to terminal."""
    vibe_score = report['vibe_score']
    stack = report['stack']
    files = report['files_analyzed']
    total = report['total_lines']

    # Color/emoji based on vibe
    if vibe_score >= 80:
        emoji = "🟢"
    elif vibe_score >= 60:
        emoji = "🟡"
    elif vibe_score >= 40:
        emoji = "🟠"
    else:
        emoji = "🔴"

    print(f"{emoji} Vibe Score: {vibe_score}/100")
    print(f"   Stack: {stack}")
    print(f"   Files: {files}, Lines: {total}")
    print()

    issues = report.get('issues', [])
    if issues:
        print("Issues detected:")
        for issue in issues:
            print(f"  • {issue}")
        print()

    ghosts = report.get('architectural_ghosts', [])
    if ghosts:
        print("👻 Architectural Ghosts:")
        for ghost in ghosts:
            print(f"   {ghost}")
        print()

    flags = report.get('red_flags', [])
    if flags:
        print("🚨 Red Flags:")
        for flag in flags:
            print(f"   {flag}")
        print()

    print("💡 Tip: Run with '--patch' to generate refactor suggestions (not yet implemented)")


def main():
    import argparse
    parser = argparse.ArgumentParser(description="Ghostclaw Architectural Analyzer")
    parser.add_argument("repo_path", help="Path to repository")
    parser.add_argument("--json", action="store_true", help="Output raw JSON report")
    
    # Engine toggles
    parser.add_argument("--pyscn", action=argparse.BooleanOptionalAction, default=None, 
                        help="Enable/disable PySCN explicitly")
    parser.add_argument("--ai-codeindex", action=argparse.BooleanOptionalAction, default=None, 
                        help="Enable/disable AI-CodeIndex explicitly")

    args = parser.parse_args()

    repo_path = args.repo_path
    output_json = args.json

    if not Path(repo_path).is_dir():
        print(f"Error: directory not found: {repo_path}", file=sys.stderr)
        sys.exit(1)

    analyzer = CodebaseAnalyzer()
    report = analyzer.analyze(
        repo_path, 
        use_pyscn=args.pyscn, 
        use_ai_codeindex=args.ai_codeindex
    )

    if output_json:
        print(json.dumps(report, indent=2))
    else:
        # Print engine badge if any engine was used
        pyscn_used = report.get("metadata", {}).get("pyscn_integrated", False)
        ai_used = report.get("metadata", {}).get("ai_codeindex_integrated", False)

        engines = []
        if pyscn_used:
            engines.append("PySCN")
        if ai_used:
            engines.append("AI-CodeIndex")

        if engines:
            print(f"🚀 Engines: {', '.join(engines)}")
            print()
            
        print_report(report)


if __name__ == "__main__":
    main()
